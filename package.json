{
  "name": "octopus-desktop",
  "version": "1.0.0",
  "description": "Octopus Desktop - AI Agent Framework",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "cd frontend && npx vite",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "build": "npm run build:frontend && npm run build:electron",
    "build:frontend": "cd frontend && npm run build",
    "build:python": "python build_python.py",
    "build:electron": "electron-builder",
    "dist": "npm run build:frontend && npm run build:python && electron-builder",
    "dist:mac": "npm run build:frontend && npm run build:python && electron-builder --mac",
    "dist:win": "npm run build:frontend && npm run build:python && electron-builder --win",
    "postinstall": "cd frontend && npm install"
  },
  "build": {
    "appId": "com.oopus.desktop",
    "productName": "Octopus",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "frontend/dist/**/*",
      "electron/**/*",
      "python-dist/**/*",
      "node_modules/**/*"
    ],
    "icon": "build/icon.png",
    "extraResources": [
      {
        "from": "python-dist",
        "to": "python-dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "electron-log": "^5.0.1",
    "electron-updater": "^6.1.7",
    "react-force-graph-2d": "^1.29.1"
  }
}
